<main>
    <div class="hero">
        <div class="container">
            <div class="left">
                <h1 class="h1">
                    Hi, I'm <b>Dương&nbsp;Thanh&nbsp;Phong</b>.
                    <br>Web Developer
                </h1>
                <p class="h3">
                    Specialized in Web Development and Building Apps
                </p>
                <div>
                    <a href="/contact" class="btn btn-primary">Contact Me</a>
                    <a href="/about" class="btn btn-secondary">About Me</a>
                </div>
            </div>
            <div class="right">
                <div class="pattern-bg"></div>
                <div class="img-box">
                    <img src="/img/thanhphong.jpg" alt="Dương Thanh Phong" class="hero-img">
                    <div class="shape shape-1"></div>
                    <div class="shape shape-2"></div>
                </div>
            </div>
        </div>
    </div>
    <div class="main">
        <div class="container">
            <div class="blog">
                <h2 class="h2">Latest Blog Post</h2>
                <div class="blog-card-group">
                    {{#if posts.length}}
                        {{#each posts}}
                            <div class="blog-card">
                                <div class="blog-content-wrapper">
                                    <!-- Hiển thị chủ đề -->
                                    <button class="blog-topic text-tiny">
                                        {{#if (eq this.category 'cong-nghe')}}💻 Công nghệ{{/if}}
                                        {{#if (eq this.category 'du-lich')}}✈️ Du lịch{{/if}}
                                        {{#if (eq this.category 'sach')}}📚 Sách{{/if}}
                                        {{#if (eq this.category 'song')}}🏡 Sống{{/if}}
                                    </button>
                                    <h3>
                                        <a href="/blogs/{{this.id}}" class="h3">
                                            {{this.title}}
                                        </a>
                                    </h3>
                                    <p class="text-sm" style="margin-bottom: 15px; color: var(--foreground-secondary);">
                                        {{this.description}}
                                    </p>
                                    <p style="margin-bottom: 15px;">
                                        <a href="/blogs/{{this.id}}" class="btn btn-secondary">Xem chi tiết</a>
                                    </p>
                                    <div class="wrapper">
                                        <span class="h4">{{this.author}}</span>
                                        <p class="text-sm">
                                            <time>{{this.createdAt}}</time>
                                        </p>
                                    </div>
                                </div>
                            </div>
                        {{/each}}
                    {{else}}
                        <p style="text-align: center; color: var(--foreground-secondary); padding: 50px;">
                            Chưa có bài viết nào. Hãy tạo bài viết đầu tiên!
                        </p>
                    {{/if}}
                </div>
            </div>
        </div>
    </div>
</main>

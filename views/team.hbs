<main>
    <div style="padding: 50px 20px; background: var(--background-secondary);">
        <div class="container">
            <h1 class="h1" style="text-align: center; margin-bottom: 50px; color: var(--foreground-primary);">
                Giới thiệu <b style="color: var(--accent);">Nhóm Chúng Tôi</b>
            </h1>

            <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 30px; max-width: 1200px; margin: 0 auto;">
                {{#each members}}
                    <div style="background: var(--background-primary); padding: 30px; border-radius: 15px; box-shadow: 0 10px 30px rgba(0,0,0,0.08); text-align: center; transition: transform 0.3s ease;">
                        <img src="{{this.avatar}}" alt="{{this.name}}" style="width: 120px; height: 120px; border-radius: 50%; object-fit: cover; margin: 0 auto 20px; border: 3px solid var(--accent);">
                        <h3 style="font-size: 1.5rem; color: var(--foreground-primary); margin-bottom: 15px;">{{this.name}}</h3>
                        <p style="margin: 8px 0; color: var(--foreground-secondary);"><strong>Tuổi:</strong> {{this.age}}</p>
                        <p style="margin: 8px 0; color: var(--foreground-secondary);"><strong>Giới tính:</strong> {{this.gender}}</p>
                        <p style="margin: 8px 0; color: var(--foreground-secondary);"><strong>Ngày sinh:</strong> {{this.birthday}}</p>
                        <p style="margin: 8px 0; color: var(--foreground-secondary);"><strong>MSSV:</strong> {{this.mssv}}</p>
                        <p style="margin: 8px 0; color: var(--foreground-secondary);"><strong>Lớp:</strong> {{this.class}}</p>
                        <p style="margin: 8px 0; color: var(--foreground-secondary);"><strong>Địa chỉ:</strong> {{this.address}}</p>
                    </div>
                {{/each}}
            </div>
        </div>
    </div>
</main>

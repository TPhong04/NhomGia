<main>
    <div style="padding: 50px 20px; background: var(--background-secondary);">
        <div class="container">
            <!-- Tiêu đề trên cùng -->
            <h1 class="h1" style="text-align: center; margin-bottom: 50px; color: var(--foreground-primary);">
                Giới thiệu <b style="color: var(--accent);">Dương Thanh Phong</b>
            </h1>

            <!-- Nội dung giới thiệu (giống layout) -->
            <div style="max-width: 800px; margin: 0 auto;">
                <div style="background: var(--background-primary); padding: 40px; border-radius: 15px; box-shadow: 0 10px 30px rgba(0,0,0,0.08); text-align: center;">
                    <!-- Ảnh đại diện (nếu có) -->
                    <div style="margin-bottom: 30px;">
                        <!-- Thay 'thanhphong.jpg' thành tên file ảnh của bạn trong public/img -->
                        <img src="/img/thanhphong.jpg" alt="Dương Thanh Phong" style="width: 150px; height: 150px; border-radius: 50%; object-fit: cover; border: 4px solid var(--accent);">
                    </div>

                    <!-- Mô tả ngắn -->
                    <p style="font-size: 1.2rem; color: var(--foreground-secondary); margin-bottom: 30px; line-height: 1.8;">
                        Tôi là sinh viên ngành Công nghệ Thông tin, yêu thích lập trình và xây dựng ứng dụng web!
                    </p>

                    <hr style="border: none; border-top: 1px solid var(--action-primary); margin: 25px 0;">

                    <!-- Thông tin chi tiết -->
                    <div style="text-align: left; max-width: 500px; margin: 0 auto;">
                        <h3 style="color: var(--foreground-primary); margin-bottom: 20px; font-size: 1.4rem; text-align: center;">Thông tin cá nhân</h3>
                        <p style="margin: 12px 0; color: var(--foreground-secondary); font-size: 1.05rem;">
                            <strong style="color: var(--accent); min-width: 100px; display: inline-block;">Tên:</strong> Dương Thanh Phong
                        </p>
                        <p style="margin: 12px 0; color: var(--foreground-secondary); font-size: 1.05rem;">
                            <strong style="color: var(--accent); min-width: 100px; display: inline-block;">Tuổi:</strong> 22
                        </p>
                        <p style="margin: 12px 0; color: var(--foreground-secondary); font-size: 1.05rem;">
                            <strong style="color: var(--accent); min-width: 100px; display: inline-block;">Lớp:</strong> 17THC
                        </p>
                        <p style="margin: 12px 0; color: var(--foreground-secondary); font-size: 1.05rem;">
                            <strong style="color: var(--accent); min-width: 100px; display: inline-block;">Địa chỉ:</strong> Cần Thơ
                        </p>
                        <p style="margin: 12px 0; color: var(--foreground-secondary); font-size: 1.05rem;">
                            <strong style="color: var(--accent); min-width: 100px; display: inline-block;">Sở thích:</strong> Lập trình, đọc sách, du lịch
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

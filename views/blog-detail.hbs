<main>
    <div style="padding: 50px 20px; background: var(--background-secondary);">
        <div class="container" style="max-width: 900px; margin: 0 auto;">
            <div style="margin-bottom: 30px;">
                <a href="/" class="btn btn-secondary">← Quay lại trang chủ</a>
            </div>

            <article style="background: var(--background-primary); border-radius: 20px; padding: 40px; box-shadow: 0 10px 30px rgba(0,0,0,0.08);">
                <div style="margin-bottom: 20px;">
                    <span class="blog-topic text-tiny">
                        {{#if (eq post.category 'cong-nghe')}}💻 Công nghệ{{/if}}
                        {{#if (eq post.category 'du-lich')}}✈️ Du lịch{{/if}}
                        {{#if (eq post.category 'sach')}}📚 Sách{{/if}}
                        {{#if (eq post.category 'song')}}🏡 Sống{{/if}}
                    </span>
                </div>

                <h1 class="h1" style="margin-bottom: 15px;">{{post.title}}</h1>

                <p class="text-lg" style="margin-bottom: 20px; color: var(--foreground-secondary);">
                    {{post.description}}
                </p>

                <div style="display: flex; gap: 20px; flex-wrap: wrap; margin-bottom: 30px; color: var(--foreground-secondary);">
                    <span><strong>Tác giả:</strong> {{post.author}}</span>
                    <span><strong>Ngày đăng:</strong> {{post.createdAt}}</span>
                </div>

                <div style="line-height: 1.8; color: var(--foreground-primary); white-space: pre-line;">
                    {{post.content}}
                </div>
            </article>
        </div>
    </div>
</main>

<main>
    <div style="padding: 50px 20px; background: var(--background-secondary);">
        <div class="container">
            <!-- Tiêu đề trên cùng -->
            <h1 class="h1" style="text-align: center; margin-bottom: 50px; color: var(--foreground-primary);">
                Liên hệ <b style="color: var(--accent);">Với Chúng Tôi</b>
            </h1>

            <!-- Form liên hệ (giống layout team) -->
            <div style="max-width: 700px; margin: 0 auto;">
                <div style="background: var(--background-primary); padding: 40px; border-radius: 15px; box-shadow: 0 10px 30px rgba(0,0,0,0.08);">
                    <!-- Thông tin liên hệ -->
                    <div style="margin-bottom: 30px;">
                        <h3 style="color: var(--foreground-primary); margin-bottom: 15px; font-size: 1.4rem;">Thông tin liên hệ</h3>
                        <p style="margin: 8px 0; color: var(--foreground-secondary);"><strong>Email:</strong> thanhphongduong1086@gmail.com</p>
                        <p style="margin: 8px 0; color: var(--foreground-secondary);"><strong>Số điện thoại:</strong> 0528845669</p>
                        <p style="margin: 8px 0; color: var(--foreground-secondary);"><strong>Địa chỉ:</strong> Cần Thơ, Việt Nam</p>
                    </div>

                    <hr style="border: none; border-top: 1px solid var(--action-primary); margin: 25px 0;">

                    <!-- Form gửi tin nhắn -->
                    <form>
                        <h3 style="color: var(--foreground-primary); margin-bottom: 20px; font-size: 1.4rem;">Gửi tin nhắn</h3>

                        <!-- Tên -->
                        <div style="margin-bottom: 20px;">
                            <label style="display: block; margin-bottom: 8px; color: var(--foreground-secondary); font-weight: 600;">Họ và tên</label>
                            <input type="text" style="width: 100%; padding: 12px 15px; border: 2px solid var(--action-primary); border-radius: 8px; font-size: 1rem; background: var(--background-secondary); color: var(--foreground-primary);">
                        </div>

                        <!-- Email -->
                        <div style="margin-bottom: 20px;">
                            <label style="display: block; margin-bottom: 8px; color: var(--foreground-secondary); font-weight: 600;">Email</label>
                            <input type="email" style="width: 100%; padding: 12px 15px; border: 2px solid var(--action-primary); border-radius: 8px; font-size: 1rem; background: var(--background-secondary); color: var(--foreground-primary);">
                        </div>

                        <!-- Tin nhắn -->
                        <div style="margin-bottom: 30px;">
                            <label style="display: block; margin-bottom: 8px; color: var(--foreground-secondary); font-weight: 600;">Nội dung tin nhắn</label>
                            <textarea rows="5" style="width: 100%; padding: 12px 15px; border: 2px solid var(--action-primary); border-radius: 8px; font-size: 1rem; background: var(--background-secondary); color: var(--foreground-primary); resize: vertical;"></textarea>
                        </div>

                        <!-- Nút gửi -->
                        <button type="submit" style="background: var(--accent); color: white; border: none; padding: 14px 30px; border-radius: 100px; font-size: 1.1rem; font-weight: 600; cursor: pointer; width: 100%; transition: background 0.3s ease;">
                            Gửi tin nhắn
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</main>
